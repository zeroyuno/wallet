<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 10.0.2.2 es la loopback del host visible solo desde el emulador de Android (NetworkModule.kt).
         Nunca resuelve a nada fuera de un emulador local, así que habilitar cleartext solo para
         este dominio no debilita la seguridad de la app en dispositivos/producción reales. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
